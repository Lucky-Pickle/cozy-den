{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cozy-den",
  "compatibility_date": "2026-06-30",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "env": {
    "staging": {
      "name": "cozy-den-staging",
      "workers_dev": true
    }
  }
}
